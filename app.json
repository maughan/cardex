{
  "expo": {
    "name": "CarDex",
    "slug": "cardex",
    "scheme": "cardex",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cardex.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CarDex uses your camera to catch cars you spot in the wild.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cardex.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "CarDex uses your camera to catch cars you spot in the wild."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CarDex tags your catches with where you found them."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3c1a3817-85dc-4b34-9316-f4be396d0162"
      }
    }
  }
}
