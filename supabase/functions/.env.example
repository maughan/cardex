# CarDex Edge Function secrets.
# Set locally in supabase/functions/.env for `supabase functions serve`,
# and in the cloud via:  supabase secrets set KEY=value
#
# SUPABASE_URL / SUPABASE_ANON_KEY are injected automatically in the cloud,
# but are needed for local serving.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # reserved for admin/seed paths

# Recognition service (the managed GPU inference endpoint + its access token)
RECOGNITION_URL=https://your-recognition-host
RECOGNITION_TOKEN=short-lived-or-service-token

# DEV: when "true", `recognize` skips the ML service and returns mock candidates
# drawn from the seeded catalogue. Leave unset/false in production.
MOCK_RECOGNITION=true
